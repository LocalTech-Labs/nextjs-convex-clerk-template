# Convex Deployment URL
# Get this from your Convex project dashboard: https://dashboard.convex.dev/
NEXT_PUBLIC_CONVEX_URL="https://your-convex-url.convex.cloud"

# Clerk JWT Issuer URL (for Convex Integration)
# This is the 'Issuer URL' (e.g., https://your-instance.clerk.accounts.dev) from your Clerk JWT Template settings.
# It's used by Convex to verify Clerk JWTs. This value is public.
# See Convex & Clerk integration docs: https://docs.convex.dev/auth/clerk
NEXT_PUBLIC_CLERK_FRONTEND_API_URL="https://your-clerk-frontend-api-url.clerk.accounts.dev"

# Clerk Publishable Key (Frontend API Key)
# Get this from your Clerk project dashboard: https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_YOUR_CLERK_PUBLISHABLE_KEY"

# Clerk Secret Key
# Get this from your Clerk project dashboard: https://dashboard.clerk.com/
# IMPORTANT: This key is secret and should not be exposed on the client-side.
CLERK_SECRET_KEY="sk_test_YOUR_CLERK_SECRET_KEY"

# Clerk Webhook Secret (for Convex user sync)
# Get this from Clerk Dashboard > Webhooks > your webhook endpoint
CLERK_WEBHOOK_SECRET="whsec_..."

# Clerk JWT Issuer Domain (for Convex auth.config.ts)
# Same as NEXT_PUBLIC_CLERK_FRONTEND_API_URL but used server-side by Convex
CLERK_JWT_ISSUER_DOMAIN="https://your-clerk-frontend-api-url.clerk.accounts.dev"

# PostHog Analytics
# Get these from your PostHog project settings: https://app.posthog.com/
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
